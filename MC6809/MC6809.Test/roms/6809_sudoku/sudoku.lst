                      (       sudoku.asm):00001         ; ============================================================================
                      (       sudoku.asm):00002         ; 6809_sudoku - Sudoku solver in Motorola 6809 assembler (lwtools: lwasm)
                      (       sudoku.asm):00003         ;
                      (       sudoku.asm):00004         ; A port of the 6502 version to the 6809. Recursive backtracking solver, same
                      (       sudoku.asm):00005         ; algorithm and same console output.
                      (       sudoku.asm):00006         ;
                      (       sudoku.asm):00007         ; Console I/O matches the 6502 build (write a byte to CONOUT to print it).
                      (       sudoku.asm):00008         ; ROM at $F000-$FFFF, 6809 vectors at $FFF0-$FFFF, working RAM from $0200.
                      (       sudoku.asm):00009         ; ============================================================================
                      (       sudoku.asm):00010         
                      (       sudoku.asm):00011         ; ---- constants -------------------------------------------------------------
                      (       sudoku.asm):00012         
     0000             (       sudoku.asm):00013         UNASSIGNED  equ 0
     0009             (       sudoku.asm):00014         BOARD_SIZE  equ 9
     0051             (       sudoku.asm):00015         CELL_COUNT  equ BOARD_SIZE*BOARD_SIZE   ; 81
     4000             (       sudoku.asm):00016         STACKTOP    equ $4000                   ; hardware stack top (RAM $0200-$3FFF)
                      (       sudoku.asm):00017         
                      (       sudoku.asm):00018         ; ---- working RAM (uninitialised) -------------------------------------------
     0200             (       sudoku.asm):00019         puzzle      equ   $0200                 ; live 9x9 board in RAM ($0200..$0250)
                      (       sudoku.asm):00020         
                      (       sudoku.asm):00021         ; ---- code ------------------------------------------------------------------
                      (       sudoku.asm):00022                     org   $F000
                      (       sudoku.asm):00023                     include "io.inc"
                      (           io.inc):00001         ; io.inc - console I/O for the 6809 sudoku port
                      (           io.inc):00002         ;
                      (           io.inc):00003         ; Memory-mapped console, matching the 6502 build: writing a byte to 6850 ACIA
                      (           io.inc):00004         ; emits a character.
                      (           io.inc):00005         
     A000             (           io.inc):00006         UART        equ $A000
     A001             (           io.inc):00007         RECEV       equ UART+1
     A001             (           io.inc):00008         TRANS       equ UART+1
     A000             (           io.inc):00009         USTAT       equ UART
     A000             (           io.inc):00010         UCTRL       equ UART
                      (           io.inc):00011         
     0003             (           io.inc):00012         ACIA_RESET  equ $03             ; master reset (CR1:CR0 = 11)
     0015             (           io.inc):00013         ACIA_CFG    equ $15             ; div-16, 8 data / no parity / 1 stop, no interrupts
                      (           io.inc):00014         
                      (           io.inc):00015         
F000                  (           io.inc):00016         io_initialise_acia:
F000 8603             (           io.inc):00017                     lda #ACIA_RESET    ; master reset must precede configuration
F002 B7A000           (           io.inc):00018                     sta UCTRL
F005 8615             (           io.inc):00019                     lda #ACIA_CFG      ; DIV16 CLOCK -> 7372800 / 4 / 16 = 115200 baud
F007 B7A000           (           io.inc):00020                     sta UCTRL
F00A 39               (           io.inc):00021                     rts
                      (           io.inc):00022         
                      (           io.inc):00023         ; io_waitacia - wait for the ACIA to become ready
F00B                  (           io.inc):00024         io_waitacia:
F00B 3402             (           io.inc):00025                     pshs a
F00D B6A000           (           io.inc):00026         io_wrwait:  lda  USTAT
F010 8502             (           io.inc):00027                     bita #2
F012 27F9             (           io.inc):00028                     beq  io_wrwait
F014 3502             (           io.inc):00029                     puls a
F016 39               (           io.inc):00030                     rts
                      (           io.inc):00031         
                      (           io.inc):00032         ; io_outchr - print the character held in A
F017                  (           io.inc):00033         io_outchr:
F017 8DF2             (           io.inc):00034                     bsr  io_waitacia        
F019 B7A001           (           io.inc):00035                     sta  TRANS           
F01C 39               (           io.inc):00036                     rts                  
                      (           io.inc):00037         
                      (           io.inc):00038         ; io_outstr - print the nul-terminated string that immediately follows the
                      (           io.inc):00039         ;             "jsr io_outstr" instruction, then resume just past the nul.
                      (           io.inc):00040         ;             (Inline-string trick, as used in the 6502 original.)
F01D                  (           io.inc):00041         io_outstr:
F01D 3510             (           io.inc):00042                     puls  x                 ; X = return address = first byte of string
F01F                  (           io.inc):00043         ios_loop:
F01F A680             (           io.inc):00044                     lda   ,x+
F021 2704             (           io.inc):00045                     beq   ios_done
F023 8DF2             (           io.inc):00046                     bsr   io_outchr
F025 20F8             (           io.inc):00047                     bra   ios_loop
F027                  (           io.inc):00048         ios_done:
F027 3410             (           io.inc):00049                     pshs  x                 ; resume after the terminating nul
F029 39               (           io.inc):00050                     rts
                      (       sudoku.asm):00024         
                      (       sudoku.asm):00025         ; ----------------------------------------------------------------------------
                      (       sudoku.asm):00026         ; reset - entry point
                      (       sudoku.asm):00027         ; ----------------------------------------------------------------------------
F02A                  (       sudoku.asm):00028         reset:
F02A 1A50             (       sudoku.asm):00029                     orcc  #$50                  ; mask IRQ and FIRQ
F02C 10CE4000         (       sudoku.asm):00030                     lds   #STACKTOP             ; set up the hardware stack
F030 BDF000           (       sudoku.asm):00031                     jsr   io_initialise_acia
                      (       sudoku.asm):00032         
                      (       sudoku.asm):00033                     ; copy the clues from ROM into writable RAM
F033 8EF1EE           (       sudoku.asm):00034                     ldx   #puzzle_init
F036 108E0200         (       sudoku.asm):00035                     ldy   #puzzle
F03A C651             (       sudoku.asm):00036                     ldb   #CELL_COUNT
F03C                  (       sudoku.asm):00037         rinit:
F03C A680             (       sudoku.asm):00038                     lda   ,x+
F03E A7A0             (       sudoku.asm):00039                     sta   ,y+
F040 5A               (       sudoku.asm):00040                     decb
F041 26F9             (       sudoku.asm):00041                     bne   rinit
                      (       sudoku.asm):00042         
F043 BDF01D           (       sudoku.asm):00043                     jsr   io_outstr
F046 536F6C76696E6720 (       sudoku.asm):00044                     fcc   "Solving puzzle: "
     70757A7A6C653A20
F056 00               (       sudoku.asm):00045                     fcb   0
                      (       sudoku.asm):00046         
F057 5F               (       sudoku.asm):00047                     clrb                        ; n = 0
F058 BDF07A           (       sudoku.asm):00048                     jsr   solve
F05B 4D               (       sudoku.asm):00049                     tsta
F05C 260D             (       sudoku.asm):00050                     bne   rfail
                      (       sudoku.asm):00051         
F05E BDF01D           (       sudoku.asm):00052                     jsr   io_outstr
F061 70617373         (       sudoku.asm):00053                     fcc   "pass"
F065 00               (       sudoku.asm):00054                     fcb   0
F066 BDF1AE           (       sudoku.asm):00055                     jsr   print_board
F069 2008             (       sudoku.asm):00056                     bra   rdone
F06B                  (       sudoku.asm):00057         rfail:
F06B BDF01D           (       sudoku.asm):00058                     jsr   io_outstr
F06E 6661696C         (       sudoku.asm):00059                     fcc   "fail"
F072 00               (       sudoku.asm):00060                     fcb   0
F073                  (       sudoku.asm):00061         rdone:
F073 860A             (       sudoku.asm):00062                     lda   #$0a                  ; trailing newline
F075 BDF017           (       sudoku.asm):00063                     jsr   io_outchr
F078                  (       sudoku.asm):00064         halt:
F078 20FE             (       sudoku.asm):00065                     bra   halt
                      (       sudoku.asm):00066         
                      (       sudoku.asm):00067         ; ----------------------------------------------------------------------------
                      (       sudoku.asm):00068         ; Inlined availability checks (macros). The row/column/box base pointers are
                      (       sudoku.asm):00069         ; precomputed once per cell and held on the stack (see solve), so each check
                      (       sudoku.asm):00070         ; is a single "ldx n,s" plus the nine comparisons. A = candidate digit.
                      (       sudoku.asm):00071         ; A conflict branches to _loop_continue; no conflict falls through.  The row
                      (       sudoku.asm):00072         ; check keeps a local 'used@' trampoline (its early compares sit >127 bytes
                      (       sudoku.asm):00073         ; from _loop_continue); column and box branch to _loop_continue directly.
                      (       sudoku.asm):00074         ;     0,s = row pointer   2,s = column pointer   4,s = box pointer
                      (       sudoku.asm):00075         ; ----------------------------------------------------------------------------
F07A                  (       sudoku.asm):00076         is_used_in_row macro
                      (       sudoku.asm):00077                     ldx   ,s                    ; puzzle + row start
                      (       sudoku.asm):00078                     cmpa  ,x
                      (       sudoku.asm):00079                     beq   used@
                      (       sudoku.asm):00080                     cmpa  1,x
                      (       sudoku.asm):00081                     beq   used@
                      (       sudoku.asm):00082                     cmpa  2,x
                      (       sudoku.asm):00083                     beq   used@
                      (       sudoku.asm):00084                     cmpa  3,x
                      (       sudoku.asm):00085                     beq   used@
                      (       sudoku.asm):00086                     cmpa  4,x
                      (       sudoku.asm):00087                     beq   used@
                      (       sudoku.asm):00088                     cmpa  5,x
                      (       sudoku.asm):00089                     beq   used@
                      (       sudoku.asm):00090                     cmpa  6,x
                      (       sudoku.asm):00091                     beq   used@
                      (       sudoku.asm):00092                     cmpa  7,x
                      (       sudoku.asm):00093                     beq   used@
                      (       sudoku.asm):00094                     cmpa  8,x
                      (       sudoku.asm):00095                     beq   used@
                      (       sudoku.asm):00096                     bra   pass@
F07A                  (       sudoku.asm):00097         used@       bra   _loop_continue   ; in range: _loop_continue is < 127 bytes ahead
F07A                  (       sudoku.asm):00098         pass@
                      (       sudoku.asm):00099                     endm
                      (       sudoku.asm):00100         
F07A                  (       sudoku.asm):00101         is_used_in_column macro
                      (       sudoku.asm):00102                     ldx   2,s                   ; puzzle + column
                      (       sudoku.asm):00103                     cmpa  ,x
                      (       sudoku.asm):00104                     beq   _loop_continue
                      (       sudoku.asm):00105                     cmpa  (BOARD_SIZE*1),x
                      (       sudoku.asm):00106                     beq   _loop_continue
                      (       sudoku.asm):00107                     cmpa  (BOARD_SIZE*2),x
                      (       sudoku.asm):00108                     beq   _loop_continue
                      (       sudoku.asm):00109                     cmpa  (BOARD_SIZE*3),x
                      (       sudoku.asm):00110                     beq   _loop_continue
                      (       sudoku.asm):00111                     cmpa  (BOARD_SIZE*4),x
                      (       sudoku.asm):00112                     beq   _loop_continue
                      (       sudoku.asm):00113                     cmpa  (BOARD_SIZE*5),x
                      (       sudoku.asm):00114                     beq   _loop_continue
                      (       sudoku.asm):00115                     cmpa  (BOARD_SIZE*6),x
                      (       sudoku.asm):00116                     beq   _loop_continue
                      (       sudoku.asm):00117                     cmpa  (BOARD_SIZE*7),x
                      (       sudoku.asm):00118                     beq   _loop_continue
                      (       sudoku.asm):00119                     cmpa  (BOARD_SIZE*8),x
                      (       sudoku.asm):00120                     beq   _loop_continue
                      (       sudoku.asm):00121                     endm
                      (       sudoku.asm):00122         
F07A                  (       sudoku.asm):00123         is_used_in_box macro
                      (       sudoku.asm):00124                     ldx   4,s                   ; puzzle + box start
                      (       sudoku.asm):00125                     cmpa  ,x
                      (       sudoku.asm):00126                     beq   _loop_continue
                      (       sudoku.asm):00127                     cmpa  1,x
                      (       sudoku.asm):00128                     beq   _loop_continue
                      (       sudoku.asm):00129                     cmpa  2,x
                      (       sudoku.asm):00130                     beq   _loop_continue
                      (       sudoku.asm):00131                     cmpa  BOARD_SIZE,x
                      (       sudoku.asm):00132                     beq   _loop_continue
                      (       sudoku.asm):00133                     cmpa  BOARD_SIZE+1,x
                      (       sudoku.asm):00134                     beq   _loop_continue
                      (       sudoku.asm):00135                     cmpa  BOARD_SIZE+2,x
                      (       sudoku.asm):00136                     beq   _loop_continue
                      (       sudoku.asm):00137                     cmpa  (BOARD_SIZE*2),x
                      (       sudoku.asm):00138                     beq   _loop_continue
                      (       sudoku.asm):00139                     cmpa  (BOARD_SIZE*2)+1,x
                      (       sudoku.asm):00140                     beq   _loop_continue
                      (       sudoku.asm):00141                     cmpa  (BOARD_SIZE*2)+2,x
                      (       sudoku.asm):00142                     beq   _loop_continue
                      (       sudoku.asm):00143                     endm
                      (       sudoku.asm):00144         
F07A                  (       sudoku.asm):00145         is_available macro
                      (       sudoku.asm):00146                     is_used_in_row
                      (       sudoku.asm):00147                     is_used_in_column
                      (       sudoku.asm):00148                     is_used_in_box
                      (       sudoku.asm):00149                     endm
                      (       sudoku.asm):00150         
                      (       sudoku.asm):00151         ; ----------------------------------------------------------------------------
                      (       sudoku.asm):00152         ; solve - recursive backtracking
                      (       sudoku.asm):00153         ;   entry: B = cell index n (0..81)
                      (       sudoku.asm):00154         ;   exit : A = 0 on success, A <> 0 on failure
                      (       sudoku.asm):00155         ;
                      (       sudoku.asm):00156         ; For each empty cell the row/column/box base pointers are computed ONCE and
                      (       sudoku.asm):00157         ; held on the stack; they do not depend on the candidate digit, so the inner
                      (       sudoku.asm):00158         ; digit loop avoids recomputing them. Per-cell stack frame:
                      (       sudoku.asm):00159         ;     0,s  row pointer    (puzzle + row start)
                      (       sudoku.asm):00160         ;     2,s  column pointer (puzzle + column)
                      (       sudoku.asm):00161         ;     4,s  box pointer    (puzzle + box start)
                      (       sudoku.asm):00162         ;     6,s  n              (cell index)
                      (       sudoku.asm):00163         ; ----------------------------------------------------------------------------
F07A                  (       sudoku.asm):00164         solve:
F07A C151             (       sudoku.asm):00165                     cmpb  #CELL_COUNT
F07C 2602             (       sudoku.asm):00166                     bne   _not_finished
F07E 4F               (       sudoku.asm):00167                     clra
F07F 39               (       sudoku.asm):00168                     rts                         ; success!
                      (       sudoku.asm):00169         
F080                  (       sudoku.asm):00170         _not_finished:
F080 8E0200           (       sudoku.asm):00171                     ldx   #puzzle
F083 A685             (       sudoku.asm):00172                     lda   b,x                   ; A = puzzle[n]
F085 2703             (       sudoku.asm):00173                     beq   sv_empty              ; empty cell -> try to fill it
F087 5C               (       sudoku.asm):00174                     incb                        ; already assigned -> skip
F088 20F0             (       sudoku.asm):00175                     bra   solve                 ; tail recursion
                      (       sudoku.asm):00176         
F08A                  (       sudoku.asm):00177         sv_empty:
F08A 3404             (       sudoku.asm):00178                     pshs  b                     ; 0,s = n
F08C 8EF3D7           (       sudoku.asm):00179                     ldx   #table_move2box_start
F08F E685             (       sudoku.asm):00180                     ldb   b,x                   ; B = box start  (B still = n)
F091 8E0200           (       sudoku.asm):00181                     ldx   #puzzle
F094 3A               (       sudoku.asm):00182                     abx
F095 3410             (       sudoku.asm):00183                     pshs  x                     ; push box pointer
F097 E662             (       sudoku.asm):00184                     ldb   2,s                   ; B = n
F099 8EF23F           (       sudoku.asm):00185                     ldx   #table_move2x
F09C E685             (       sudoku.asm):00186                     ldb   b,x                   ; B = column
F09E 8E0200           (       sudoku.asm):00187                     ldx   #puzzle
F0A1 3A               (       sudoku.asm):00188                     abx
F0A2 3410             (       sudoku.asm):00189                     pshs  x                     ; push column pointer
F0A4 E664             (       sudoku.asm):00190                     ldb   4,s                   ; B = n
F0A6 8EF386           (       sudoku.asm):00191                     ldx   #table_move2row_start
F0A9 E685             (       sudoku.asm):00192                     ldb   b,x                   ; B = row start
F0AB 8E0200           (       sudoku.asm):00193                     ldx   #puzzle
F0AE 3A               (       sudoku.asm):00194                     abx
F0AF 3410             (       sudoku.asm):00195                     pshs  x                     ; push row pointer
F0B1 8601             (       sudoku.asm):00196                     lda   #1                    ; first candidate digit
                      (       sudoku.asm):00197         
F0B3                  (       sudoku.asm):00198         _loop:
                      (       sudoku.asm):00199                     is_available                ; A = digit; conflict -> _loop_continue
                      (     is_available):00001                     is_used_in_row
F0B3 AEE4             (   is_used_in_row):00001                     ldx   ,s                    ; puzzle + row start
F0B5 A184             (   is_used_in_row):00002                     cmpa  ,x
F0B7 2722             (   is_used_in_row):00003                     beq   used@
F0B9 A101             (   is_used_in_row):00004                     cmpa  1,x
F0BB 271E             (   is_used_in_row):00005                     beq   used@
F0BD A102             (   is_used_in_row):00006                     cmpa  2,x
F0BF 271A             (   is_used_in_row):00007                     beq   used@
F0C1 A103             (   is_used_in_row):00008                     cmpa  3,x
F0C3 2716             (   is_used_in_row):00009                     beq   used@
F0C5 A104             (   is_used_in_row):00010                     cmpa  4,x
F0C7 2712             (   is_used_in_row):00011                     beq   used@
F0C9 A105             (   is_used_in_row):00012                     cmpa  5,x
F0CB 270E             (   is_used_in_row):00013                     beq   used@
F0CD A106             (   is_used_in_row):00014                     cmpa  6,x
F0CF 270A             (   is_used_in_row):00015                     beq   used@
F0D1 A107             (   is_used_in_row):00016                     cmpa  7,x
F0D3 2706             (   is_used_in_row):00017                     beq   used@
F0D5 A108             (   is_used_in_row):00018                     cmpa  8,x
F0D7 2702             (   is_used_in_row):00019                     beq   used@
F0D9 2002             (   is_used_in_row):00020                     bra   pass@
F0DB 206A             (   is_used_in_row):00021         used@       bra   _loop_continue   ; in range: _loop_continue is < 127 bytes ahead
F0DD                  (   is_used_in_row):00022         pass@
                      (     is_available):00002                     is_used_in_column
F0DD AE62             (is_used_in_column):00001                     ldx   2,s                   ; puzzle + column
F0DF A184             (is_used_in_column):00002                     cmpa  ,x
F0E1 2764             (is_used_in_column):00003                     beq   _loop_continue
F0E3 A109             (is_used_in_column):00004                     cmpa  (BOARD_SIZE*1),x
F0E5 2760             (is_used_in_column):00005                     beq   _loop_continue
F0E7 A18812           (is_used_in_column):00006                     cmpa  (BOARD_SIZE*2),x
F0EA 275B             (is_used_in_column):00007                     beq   _loop_continue
F0EC A1881B           (is_used_in_column):00008                     cmpa  (BOARD_SIZE*3),x
F0EF 2756             (is_used_in_column):00009                     beq   _loop_continue
F0F1 A18824           (is_used_in_column):00010                     cmpa  (BOARD_SIZE*4),x
F0F4 2751             (is_used_in_column):00011                     beq   _loop_continue
F0F6 A1882D           (is_used_in_column):00012                     cmpa  (BOARD_SIZE*5),x
F0F9 274C             (is_used_in_column):00013                     beq   _loop_continue
F0FB A18836           (is_used_in_column):00014                     cmpa  (BOARD_SIZE*6),x
F0FE 2747             (is_used_in_column):00015                     beq   _loop_continue
F100 A1883F           (is_used_in_column):00016                     cmpa  (BOARD_SIZE*7),x
F103 2742             (is_used_in_column):00017                     beq   _loop_continue
F105 A18848           (is_used_in_column):00018                     cmpa  (BOARD_SIZE*8),x
F108 273D             (is_used_in_column):00019                     beq   _loop_continue
                      (     is_available):00003                     is_used_in_box
F10A AE64             (   is_used_in_box):00001                     ldx   4,s                   ; puzzle + box start
F10C A184             (   is_used_in_box):00002                     cmpa  ,x
F10E 2737             (   is_used_in_box):00003                     beq   _loop_continue
F110 A101             (   is_used_in_box):00004                     cmpa  1,x
F112 2733             (   is_used_in_box):00005                     beq   _loop_continue
F114 A102             (   is_used_in_box):00006                     cmpa  2,x
F116 272F             (   is_used_in_box):00007                     beq   _loop_continue
F118 A109             (   is_used_in_box):00008                     cmpa  BOARD_SIZE,x
F11A 272B             (   is_used_in_box):00009                     beq   _loop_continue
F11C A10A             (   is_used_in_box):00010                     cmpa  BOARD_SIZE+1,x
F11E 2727             (   is_used_in_box):00011                     beq   _loop_continue
F120 A10B             (   is_used_in_box):00012                     cmpa  BOARD_SIZE+2,x
F122 2723             (   is_used_in_box):00013                     beq   _loop_continue
F124 A18812           (   is_used_in_box):00014                     cmpa  (BOARD_SIZE*2),x
F127 271E             (   is_used_in_box):00015                     beq   _loop_continue
F129 A18813           (   is_used_in_box):00016                     cmpa  (BOARD_SIZE*2)+1,x
F12C 2719             (   is_used_in_box):00017                     beq   _loop_continue
F12E A18814           (   is_used_in_box):00018                     cmpa  (BOARD_SIZE*2)+2,x
F131 2714             (   is_used_in_box):00019                     beq   _loop_continue
                      (       sudoku.asm):00200         
                      (       sudoku.asm):00201                     ; available: place the digit and recurse
F133 E666             (       sudoku.asm):00202                     ldb   6,s                   ; B = n
F135 8E0200           (       sudoku.asm):00203                     ldx   #puzzle
F138 A785             (       sudoku.asm):00204                     sta   b,x                   ; puzzle[n] = digit
F13A 3402             (       sudoku.asm):00205                     pshs  a                     ; 0,s = digit ; n now at 7,s
F13C E667             (       sudoku.asm):00206                     ldb   7,s                   ; B = n
F13E 5C               (       sudoku.asm):00207                     incb                        ; recurse on n+1
                      (       sudoku.asm):00208         
F13F BDF07A           (       sudoku.asm):00209                     jsr   solve
                      (       sudoku.asm):00210         
F142 4D               (       sudoku.asm):00211                     tsta
F143 2715             (       sudoku.asm):00212                     beq   _return_true
                      (       sudoku.asm):00213         
F145 3502             (       sudoku.asm):00214                     puls  a                     ; A = digit ; frame restored
                      (       sudoku.asm):00215                     ; fall through to try the next digit
F147                  (       sudoku.asm):00216         _loop_continue:
F147 4C               (       sudoku.asm):00217                     inca
F148 810A             (       sudoku.asm):00218                     cmpa  #BOARD_SIZE+1
F14A 1026FF65         (       sudoku.asm):00219                     lbne  _loop                ; _loop is > 127 bytes back
                      (       sudoku.asm):00220         
                      (       sudoku.asm):00221                                                ; failure, unmake & try again
